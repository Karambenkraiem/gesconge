# Copy to .env.prod on the VPS (in /opt/steg/gesconge) and fill in real values.
# Never commit the real .env.prod file.

DB_USER=gesconge_user
DB_PASSWORD=change-me-strong-password
DB_NAME=gesconge_db

# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-min-32-random-chars

FRONTEND_URL=https://gesconge.alkaramsoft.ovh
NEXT_PUBLIC_API_URL=https://gesconge.alkaramsoft.ovh/api
